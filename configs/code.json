{
  // === Tema ===
  "workbench.colorTheme": "One Dark Pro Darker",
  "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-dark",

  // === Editor ===
  "editor.fontSize": 16,
  "editor.fontFamily": "JetBrainsMono Nerd Font, JetBrainsMono NF, monospace",
  "editor.fontWeight": "bold",
  "editor.minimap.enabled": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,

  // === Markdown i Notebooks ===
  "markdown.preview.fontFamily": "'Inter', Arial, sans-serif",
  "markdown.preview.fontSize": 16,
  "markdown.validate.enabled": false,
  "markdown.suggest.paths.enabled": false,

  // === Terminal ===
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.shellArgs.linux": ["-l"],
  "terminal.integrated.fontFamily": "JetBrainsMono NF",
  "terminal.integrated.fontLigatures.enabled": true,

  // === Arxius ===
  "files.autoSave": "afterDelay",
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreview": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // === Git ===
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "githubPullRequests.createOnPublishBranch": "never",

  // === Python ===
  "python.analysis.typeCheckingMode": "standard",
  "python.defaultInterpreterPath": "/bin/python3.14",

  // === Mise ===
  "mise.binPath": "/home/miquel/.local/bin/mise",

  // === C/C++ ===
  "C_Cpp.copilotHover": "disabled",

  // === Chat/AI ===
  "chat.agent.enabled": false,

  // === Tokenizació (cursives personalitzades) ===
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Comentarios en cursiva",
        "scope": ["comment", "punctuation.definition.comment"],
        "settings": { "fontStyle": "italic" },
      },
      {
        "name": "Keywords en cursiva",
        "scope": [
          "keyword.control",
          "keyword.control.flow",
          "keyword.control.import",
          "keyword.control.export",
          "keyword.control.from",
        ],
        "settings": { "fontStyle": "italic" },
      },
      {
        "name": "Variables en cursiva",
        "scope": ["variable.other.readwrite", "variable.other", "variable"],
        "settings": { "fontStyle": "italic" },
      },
    ],
  },
  "security.workspace.trust.untrustedFiles": "open",
  "notebook.lineNumbers": "on",
  "chat.disableAIFeatures": true,
  "java.imports.gradle.wrapper.checksums": [
    {
      "sha256": "2c23278a62dc9f96ab11bee897d9f53e6479d6419135e4560ce822a6431df5e5",
      "allowed": true,
    },
  ],
  "cmake.showConfigureWithDebuggerNotification": false,
  "claudeCode.preferredLocation": "panel",
}
